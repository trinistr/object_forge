#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"

# Load this gem
gem_name = File.basename(Dir["*.rb", base: "#{__dir__}/../lib"].first)
require gem_name

FoobarStruct = Struct.new(:foo, :bar, keyword_init: true)
Point = Struct.new(:id, :x, :y)

FORGEYARD = ObjectForge::Forgeyard.new
FORGE =
  FORGEYARD.define(:foobar, FoobarStruct) do |f|
    f.foo { bar - 1 }
    f.sequence(:bar)

    f.trait :zero do
      f.foo { 0 }
    end
  end

FAST_FORGE =
  FORGEYARD.define(:sea, Hash) do |f|
    f.crucible = ->(attributes) { attributes.transform_values(&:call) }

    f.wide { true }
    f.deep { false }

    f.trait :pond do
      f.wide { false }
    end

    f.trait :ocean do
      f.deep { true }
    end
  end

# Start interactive console
require "irb"
IRB.start(__FILE__)
